# Trustela 환경변수 예시 — 이 파일을 복사해 `.env.local` 로 만들고 값을 채우세요.
# ⚠️ API 키 발급·결제·계정 생성은 보안상 본인이 직접 해야 합니다.

# --- LLM 엔진 커넥터 (Phase 1: ChatGPT + Perplexity 우선) ---
# OpenAI (ChatGPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Perplexity — https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# (선택, Phase 1 3번째 엔진 후보) Google Gemini — https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- 전환형 인용 분류에 쓸 모델 (PRD E5) ---
# 분류용 LLM. 미설정 시 OPENAI_API_KEY 사용.
# CLASSIFIER_MODEL=

# --- 데이터 저장소 (시계열 결과) ---
# Postgres 연결 문자열. Supabase/Neon 등 관리형 무료 티어 권장.
# DATABASE_URL=postgres://user:pass@host:5432/trustela

# --- 잡 큐 / 스케줄러 (프롬프트 정기 실행) ---
# 예: Upstash QStash / Vercel Cron. Phase 1은 미설정으로 수동 실행부터 시작 가능.
# QSTASH_TOKEN=
